{
    "name": "chandra2004/lara-hosted-free",
    "description": "Custom admin artisan and log viewer bypass for shared hosting",
    "type": "library",
    "license": "MIT",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "authors": [
        {
            "name": "Chandra",
            "email": "chandratriantomo123@gmail.com"
        }
    ],
    "require": {
        "php": "^8.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
    },
    "suggest": {
        "opcodesio/log-viewer": "^3.24"
    },
    "autoload": {
        "psr-4": {
            "Chanzz\\LaraHostedFree\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Chanzz\\LaraHostedFree\\Providers\\LaraHostedFreeServiceProvider"
            ]
        }
    }
}
